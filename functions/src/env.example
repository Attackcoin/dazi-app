# Firebase Functions 环境变量
# 使用方法：
#   firebase functions:config:set claude.api_key="YOUR_KEY"
#   firebase functions:config:set aliyun.access_key_id="YOUR_ID"
#   ... 以此类推
#
# 本地开发时，运行：
#   firebase functions:config:get > .runtimeconfig.json
# 然后 emulator 会自动读取

# Claude AI (Anthropic)
CLAUDE_API_KEY=sk-ant-...

# 阿里云实人认证
ALIYUN_ACCESS_KEY_ID=...
ALIYUN_ACCESS_KEY_SECRET=...
ALIYUN_REGION=cn-hangzhou

# 微信支付
WECHAT_PAY_APP_ID=...
WECHAT_PAY_MCH_ID=...
WECHAT_PAY_API_KEY=...

# 支付宝
ALIPAY_APP_ID=...
ALIPAY_PRIVATE_KEY=...
ALIPAY_PUBLIC_KEY=...

# Algolia
ALGOLIA_APP_ID=...
ALGOLIA_ADMIN_KEY=...

# !! 绝对不要把这个文件提交到 Git !!
# !! 已在 .gitignore 中排除 .runtimeconfig.json !!
