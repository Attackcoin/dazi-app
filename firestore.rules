rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users ─────────────────────────────────────────────
    // 任何登录用户可读基础信息，本人才能修改（字段白名单保护敏感字段）
    match /users/{userId} {
      allow read: if request.auth != null;
      // 新建账号：允许本人写入基础字段（注册时由前端写入）
      allow create: if request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'name', 'bio', 'avatar', 'city', 'gender', 'age', 'tags',
          'fcmToken', 'sesameAuthorized', 'notificationSettings',
          'rating', 'reviewCount', 'ratingSum', 'ratingCount',
          'ghostCount', 'totalMeetups', 'badges', 'isRestricted',
          'createdAt', 'updatedAt'
        ]);
      // 更新：本人只能改可编辑字段；rating/ghostCount/isRestricted/badges 由 Cloud Functions 维护
      allow update: if request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'bio', 'avatar', 'city', 'gender', 'age', 'tags',
          'fcmToken', 'sesameAuthorized', 'notificationSettings'
        ]);
    }

    // ── posts ─────────────────────────────────────────────
    // 登录用户可读，登录用户可创建（字段白名单），发布者才能修改/删除
    match /posts/{postId} {
      allow read: if request.auth != null;
      // 创建：字段白名单，防止注入 status/rating 等服务端字段
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'userId', 'title', 'description', 'category', 'time',
          'location', 'totalSlots', 'gender', 'genderQuota',
          'costType', 'depositAmount', 'images', 'tags',
          'isSocialAnxietyFriendly', 'status',
          'acceptedGender', 'waitlist', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.userId == request.auth.uid;
      // 更新：发布者只能改业务可编辑字段
      allow update: if request.auth.uid == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title', 'description', 'category', 'time', 'location',
          'totalSlots', 'gender', 'genderQuota', 'costType',
          'depositAmount', 'images', 'tags', 'isSocialAnxietyFriendly',
          'status', 'acceptedGender', 'waitlist', 'updatedAt'
        ]);
      allow delete: if request.auth.uid == resource.data.userId;
    }

    // ── applications ──────────────────────────────────────
    // 申请者本人 或 帖子发布者 才能读取
    match /applications/{appId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.applicantId ||
        request.auth.uid == get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.userId
      );
      allow create: if request.auth != null;
      allow update: if request.auth.uid == get(
        /databases/$(database)/documents/posts/$(resource.data.postId)
      ).data.userId;
    }

    // ── matches ───────────────────────────────────────────
    // 参与者才能读取；写入由 Cloud Functions 负责，
    // 唯一例外：参与者可以更新 lastMessageAt / lastMessagePreview
    // 这两个字段（聊天发消息时同步，由前端直写以避免一次 Cloud Function 往返）
    match /matches/{matchId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastMessageAt', 'lastMessagePreview']);
      allow create, delete: if false;
    }

    // ── deposits ──────────────────────────────────────────
    // 只有本人可以读，写入由 Functions 负责
    match /deposits/{depId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    // ── reviews ───────────────────────────────────────────
    // 文档 ID 格式：{matchId}_{fromUid}_{toUid}，天然防重复评价
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      // create：要求 fromUser == 当前用户，且该文档不存在（复合 ID 保证幂等）
      allow create: if request.auth != null
        && request.resource.data.fromUser == request.auth.uid
        && !exists(/databases/$(database)/documents/reviews/$(reviewId));
      allow update, delete: if false;
    }

    // ── reports ───────────────────────────────────────────
    match /reports/{repId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // ── monthlyReports ────────────────────────────────────
    match /monthlyReports/{reportId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow write: if false;
    }
  }
}
