rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users ─────────────────────────────────────────────
    // 任何登录用户可读基础信息，本人才能修改（字段白名单保护敏感字段）
    match /users/{userId} {
      allow read: if request.auth != null;
      // 新建账号：允许本人写入基础字段（注册时由前端写入）
      // 信誉/风控字段（rating/ghostCount/isRestricted/...）必须为默认值，
      // 防止用户注册时自行给自己刷高评分或解除限制
      allow create: if request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'name', 'bio', 'avatar', 'city', 'gender', 'age', 'birthYear', 'tags',
          'fcmToken', 'fcmTokenUpdatedAt', 'sesameAuthorized',
          'notificationsPrefs', 'privacyPrefs',
          'emergencyContacts', 'blockedUsers',
          'rating', 'reviewCount', 'ratingSum', 'ratingCount',
          'ghostCount', 'totalMeetups', 'badges', 'isRestricted',
          'isSocialAnxietyFriendly', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.rating == 5.0
        && request.resource.data.reviewCount == 0
        && request.resource.data.ratingSum == 0
        && request.resource.data.ratingCount == 0
        && request.resource.data.ghostCount == 0
        && request.resource.data.totalMeetups == 0
        && request.resource.data.badges.size() == 0
        && request.resource.data.isRestricted == false;
      // 更新：本人只能改可编辑字段；rating/ghostCount/isRestricted/badges 由 Cloud Functions 维护
      allow update: if request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'bio', 'avatar', 'city', 'gender', 'age', 'birthYear', 'tags',
          'fcmToken', 'fcmTokenUpdatedAt', 'sesameAuthorized',
          'notificationsPrefs', 'privacyPrefs',
          'emergencyContacts', 'blockedUsers',
          'isSocialAnxietyFriendly', 'updatedAt'
        ]);
    }

    // ── config（公开只读，写入由部署脚本/控制台执行）──────
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── posts ─────────────────────────────────────────────
    // 登录用户可读，登录用户可创建（字段白名单），发布者才能修改/删除
    match /posts/{postId} {
      allow read: if request.auth != null;
      // 创建：字段白名单，防止注入 rating 等服务端字段
      // 初始 status 必须为 'open'，waitlist 必须为空——由 Cloud Functions 后续推进
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'userId', 'title', 'description', 'category', 'time',
          'location', 'totalSlots', 'minSlots', 'gender', 'genderQuota',
          'costType', 'depositAmount', 'images', 'tags',
          'isSocialAnxietyFriendly', 'isInstant', 'status',
          'acceptedGender', 'waitlist', 'createdAt', 'updatedAt', 'expiresAt',
          'publisherName', 'publisherAvatar',
          'seriesId', 'recurrence', 'seriesWeek', 'seriesTotalWeeks',
          'womenOnly', 'participationFee'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.waitlist.size() == 0;
      // 更新：发布者只能改业务可编辑字段 + 取消帖子（status=cancelled）
      // acceptedGender/waitlist 由 Cloud Functions 维护（申请/接受时更新），
      // status 只允许客户端改成 'cancelled'（发布者主动取消），其他转移由 Functions 负责
      allow update: if request.auth.uid == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title', 'description', 'category', 'time', 'location',
          'totalSlots', 'gender', 'genderQuota', 'costType',
          'depositAmount', 'images', 'tags', 'isSocialAnxietyFriendly',
          'status', 'updatedAt'
        ])
        && (!('status' in request.resource.data.diff(resource.data).affectedKeys())
            || request.resource.data.status == 'cancelled');
      allow delete: if request.auth.uid == resource.data.userId;
    }

    // ── applications ──────────────────────────────────────
    // 申请者本人 或 帖子发布者 才能读取
    match /applications/{appId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.applicantId ||
        request.auth.uid == get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.userId
      );
      // M-3: 创建时要求 applicantId 必须是自己且初始 status='pending'，
      // 防止冒用他人身份创建申请或伪造状态绕过 acceptApplication 流程
      allow create: if request.auth != null
        && request.resource.data.applicantId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if request.auth.uid == get(
        /databases/$(database)/documents/posts/$(resource.data.postId)
      ).data.userId;
    }

    // ── matches ───────────────────────────────────────────
    // 参与者才能读取；写入由 Cloud Functions 负责，
    // 唯一例外：参与者可以更新 lastMessageAt / lastMessagePreview
    // 这两个字段（聊天发消息时同步，由前端直写以避免一次 Cloud Function 往返）
    match /matches/{matchId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastMessageAt', 'lastMessagePreview', 'lastReadAt']);
      allow create, delete: if false;
    }

    // ── deposits ──────────────────────────────────────────
    // 只有本人可以读，写入由 Functions 负责
    match /deposits/{depId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    // ── reviews ───────────────────────────────────────────
    // 文档 ID 格式：{matchId}_{fromUid}_{toUid}，天然防重复评价
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      // create：要求 fromUser == 当前用户，且该文档不存在（复合 ID 保证幂等）
      allow create: if request.auth != null
        && request.resource.data.fromUser == request.auth.uid
        && !exists(/databases/$(database)/documents/reviews/$(reviewId));
      allow update, delete: if false;
    }

    // ── safetyAlerts ────────────────────────────────────────
    // 用户只能读自己的安全提醒；写入由 Cloud Functions 负责
    match /safetyAlerts/{alertId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // ── circles ──────────────────────────────────────────
    // 圈子主文档：登录用户可读，创建/更新/删除由 Cloud Functions 负责
    match /circles/{circleId} {
      allow read: if request.auth != null;
      allow write: if false;

      // 成员子集合：登录用户可读成员列表，写入由 Cloud Functions 负责
      match /members/{memberId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // 动态子集合：圈子成员可读，写入由 Cloud Functions 负责
      match /moments/{momentId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // ── venues ───────────────────────────────────────────
    // 合作场地：登录用户可读，写入由 Cloud Functions 负责
    match /venues/{venueId} {
      allow read: if request.auth != null;
      allow write: if false;

      // 签到子集合：登录用户可读自己的签到，写入由 Cloud Functions 负责
      match /checkins/{checkinId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // ── voiceRooms ────────────────────────────────────────
    // 语音房：登录用户可读，写入由 Cloud Functions 负责
    match /voiceRooms/{roomId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── reports ───────────────────────────────────────────
    match /reports/{repId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // ── activityPayments ───────────────────────────────────
    // 参与者或发布者可读自己的支付记录，写入由 Cloud Functions 负责
    match /activityPayments/{payId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.auth.uid == resource.data.publisherId
      );
      allow write: if false;
    }

    // ── monthlyReports ────────────────────────────────────
    match /monthlyReports/{reportId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow write: if false;
    }
  }
}
